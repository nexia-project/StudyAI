# ─── StudyAI — Railway Environment Variables ─────────────────────────────────
# Copie este arquivo, preencha os valores e configure no dashboard do Railway.
# Em Railway: Settings → Variables → Add Variable

# ── Obrigatórias ──────────────────────────────────────────────────────────────

NODE_ENV=production

# Railway injeta PORT automaticamente — NÃO definir manualmente
# PORT=

# PostgreSQL — use o plugin Railway Postgres (fornecido automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Clerk — Autenticação ──────────────────────────────────────────────────────
# Em: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── OpenRouter — Claude + DeepSeek (sua chave própria) ────────────────────────
# Em: https://openrouter.ai/keys
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-...
# Para Admin IA & Custos consultar saldo real em /credits (management key)
OPENROUTER_MANAGEMENT_API_KEY=sk-or-...

# ── OpenAI — TTS (voz Tiagão) + Whisper STT (sua chave própria) ──────────────
# Em: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# Para Admin IA & Custos consultar /v1/organization/costs
OPENAI_ADMIN_API_KEY=sk-...
# OPENAI_ORG_ID=org_...
# OPENAI_PROJECT_ID=proj_...

# ── Billing/uso real de provedores opcionais ──────────────────────────────────
# Anthropic Cost Report exige Admin API key (sk-ant-admin...), não ANTHROPIC_API_KEY comum
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin...
# ElevenLabs retorna uso real de caracteres/limite em /v1/user/subscription
ELEVENLABS_API_KEY=
# Gemini/Google: fatura real exige Google Cloud Billing Export/API fora de GEMINI_API_KEY
# GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_CLOUD_BILLING_ACCOUNT_ID=
# GOOGLE_CLOUD_BILLING_EXPORT=
# DeepSeek direto não está implementado; deepseek/* roda via OpenRouter
# DEEPSEEK_API_KEY=
# Anthropic direto não é usado no runtime atual; Claude roda via OpenRouter
# ANTHROPIC_API_KEY=

# ── WhatsApp / Meta Cloud API ─────────────────────────────────────────────────
# Sem esses valores, comunicação institucional fica em dry_run/configuration_required
WHATSAPP_PROVIDER=disabled
# WHATSAPP_PROVIDER=meta
# WHATSAPP_META_ACCESS_TOKEN=
# WHATSAPP_META_PHONE_NUMBER_ID=
# WHATSAPP_META_BUSINESS_ACCOUNT_ID=
WHATSAPP_META_TEMPLATE_LANGUAGE=pt_BR

# ── Stripe — Pagamentos ───────────────────────────────────────────────────────
# Em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ── Resend — Emails transacionais ─────────────────────────────────────────────
# Em: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Segurança ─────────────────────────────────────────────────────────────────
# String aleatória para proteger endpoints de cron (gere com: openssl rand -hex 32)
CRON_SECRET=random_secret_here

# Hermes admin agents — cron secret para /internal/hermes/* endpoints (Railway Cron)
# Header esperado: x-cron-secret: <valor>
HERMES_CRON_SECRET=

# Simulado ENEM — fonte do banco de questões: `json` (padrão, JSON embutido + opcional ENEM_BANK_JSON_PATH) ou `db` (Postgres `enem_questions`, após ingest:enem-db)
ENEM_BANK_SOURCE=json
# ENEM_BANK_JSON_PATH=

# Ingest ENEM → Postgres: JSON fonte (caminho relativo ao cwd ou absoluto). Usado por `pnpm ingest:enem-db`.
# ENEM_INGEST_JSON=

# ── Administradores ───────────────────────────────────────────────────────────
# Emails separados por vírgula (sem espaço) que têm acesso admin
ADMIN_EMAILS=seu@email.com
# IDs Clerk separados por vírgula
ADMIN_USER_IDS=user_...

# ── Logs (opcional) ───────────────────────────────────────────────────────────
LOG_LEVEL=info
