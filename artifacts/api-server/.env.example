# StudyAI — api-server example environment variables
# Copy to `.env` and fill in values. Only the math integration is documented
# here; for the full set of secrets see `.env.railway.example` at repo root.

# ─── Math / Exatas (PR-7) ─────────────────────────────────────────────────────
# Optional. When set, math solving uses Wolfram Alpha (paid, ~US$ 2-25/mo).
# When not set, falls back to free engine (mathjs + algebrite).
WOLFRAM_APP_ID=

# ─── Visuals (imagens em slides/resumos/aula-ia) ──────────────────────────────
# Camada 1 (grátis): busca em Wikimedia Commons (CC-BY/CC0) — sempre ativa.
# Camada 2 (paga, fallback): geração com IA quando o banco curado não tem hit.
# - TOGETHER_API_KEY  → FLUX schnell via Together AI (~US$ 0.003/img). Default.
# - OPENAI_API_KEY    → DALL-E 3 (~US$ 0.04/img). Usado quando tier="premium".
# Sem nenhuma das duas chaves, o sistema usa só Wikimedia + placeholder estático.
# Kill switch: VISUALS_ENABLED=false desliga geração de IA mesmo com chave.
TOGETHER_API_KEY=
OPENAI_API_KEY=
VISUALS_ENABLED=

# ─── Admin IA & Custos — billing/saldo real opcional ──────────────────────────
# OpenRouter credits exige management key/permissão de credits.
OPENROUTER_MANAGEMENT_API_KEY=
# OpenAI Costs API exige chave com permissão de Usage/Costs da organização/projeto.
OPENAI_ADMIN_API_KEY=
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=
# Anthropic Cost Report exige Admin API key (sk-ant-admin...), não chave de mensagens.
ANTHROPIC_ADMIN_API_KEY=
# ElevenLabs expõe uso real de caracteres/limite de assinatura.
ELEVENLABS_API_KEY=

# ─── YouTube Data API v3 — gera videos educacionais em respostas (opcional) ──
# Sem chave: cai no banco curado de 30+ topicos hardcoded (canais brasileiros
# confiaveis: Khan Academy BR, Curso Enem Gratuito, Me Salva, Manual do Mundo,
# Nerdologia, Biologia Total, Matematica Rio, Professor Noslen, etc.).
# Criar em https://console.cloud.google.com/apis/credentials apos habilitar
# YouTube Data API v3. Quota padrao: 10k unidades/dia (~100 buscas unicas/dia).
# Cache 24h agressivo + filtro de whitelist mantem o uso saudavel.
YOUTUBE_API_KEY=

# ─── Hermes admin agents (gestão + crescimento) ───────────────────────────────
# Cron secret para /internal/hermes/* endpoints (Railway Cron).
# Header esperado: x-cron-secret: <valor>
HERMES_CRON_SECRET=
